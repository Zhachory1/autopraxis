{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Zhachory1/autopraxis/schemas/telemetry-event-v1.schema.json",
  "title": "Autopraxis Telemetry Event v1",
  "type": "object",
  "required": ["schema_version", "ts", "run_id", "workflow", "step", "event", "status"],
  "properties": {
    "schema_version": { "const": 1 },
    "ts": { "type": "string" },
    "run_id": { "type": "string", "minLength": 1 },
    "workflow": { "type": "string", "minLength": 1 },
    "step": { "type": "string", "minLength": 1 },
    "event": { "enum": ["start", "end", "gate", "loop", "escalation", "validation", "human_response"] },
    "status": { "enum": ["ok", "fail", "blocked", "skipped", "inconclusive"] },
    "latency_ms": { "type": ["number", "null"], "minimum": 0 },
    "cost_usd": { "type": ["number", "null"], "minimum": 0 },
    "cost_source": { "enum": ["provider_reported", "estimated", "user_supplied", null] },
    "token_source": { "enum": ["provider_reported", "estimated", "user_supplied", null] },
    "tokens_in": { "type": ["integer", "null"], "minimum": 0 },
    "tokens_out": { "type": ["integer", "null"], "minimum": 0 },
    "provider": { "type": ["string", "null"] },
    "model": { "type": ["string", "null"] },
    "tools": { "type": "array", "items": { "type": "string" } },
    "artifact_refs": { "type": "array", "items": { "type": "string" } },
    "metrics": { "type": "object" },
    "verdict": { "type": ["string", "null"] },
    "loop_iteration": { "type": ["integer", "null"], "minimum": 0 },
    "loop_cap": { "type": ["integer", "null"], "minimum": 0 },
    "human_edit_rate": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "escalation_reason": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] }
  },
  "additionalProperties": true
}
