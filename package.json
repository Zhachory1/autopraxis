  },
  "files": [
    ".agents/plugins/marketplace.json",
    ".cave-plugin/",
    ".claude-plugin/",
    ".codex-plugin/",
    "README.md",
    "INSTALL.md",
    "CHANGELOG.md",
    "RELEASE.md",
    "autopraxis.json",
    "assets/",
    "bin/",
    "evals/",
    "examples/",
    "releases/",
    "skills/",
    "vendor/"
